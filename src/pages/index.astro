---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { catalog, collectionLabels, getImage } from '../data/catalog';

const counts = {
  all: catalog.length,
  watercolor: catalog.filter(a => a.collection === 'watercolor').length,
  digital: catalog.filter(a => a.collection === 'digital').length,
  ai: catalog.filter(a => a.collection === 'ai').length,
  multimedia: catalog.filter(a => a.collection === 'multimedia').length,
};

// Pre-resolve all optimized image URLs for the client-side hero script
const heroImageUrls = catalog.map(a => {
  const img = getImage(a);
  return img.src;
});

// Use geisha piece as the OG image (vivid, representative)
const ogImageSrc = getImage(catalog.find(a => a.slug === 'geisha')!).src;
---

<BaseLayout currentPath="/" ogImage={`https://joefuqua.art${ogImageSrc}`}>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-image">
      <Image id="hero-img" src={getImage(catalog[0])} alt="Featured artwork" widths={[800, 1200, 1920]} format="webp" quality={80} />
    </div>
    <div class="hero-vignette"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Visual Work · Charlotte, NC</div>
      <h1 class="hero-title">
        Made by hand.<br/>
        Made by algorithm.<br/>
        <em>Made by whatever lives between.</em>
      </h1>
      <p class="hero-body">Watercolor impressionism. Digital charcoal. AI-generated horror. Generative particle systems. And the space between — where digital becomes physical through ink, gel, and paint.</p>
      <div class="hero-actions">
        <a href="#gallery" class="btn-primary">View Gallery</a>
        <a href="mailto:joe@joefuqua.blog" class="btn-ghost">Inquire About Prints</a>
      </div>
    </div>
  </section>

  <!-- COLLECTION NAV -->
  <div class="collection-nav" id="collection-nav">
    <a href="/#gallery" class="collection-tab active" data-col="all">
      All<span class="collection-count">{counts.all}</span>
    </a>
    <a href="/?collection=watercolor#gallery" class="collection-tab" data-col="watercolor">
      Watercolor<span class="collection-count">{counts.watercolor}</span>
    </a>
    <a href="/?collection=digital#gallery" class="collection-tab" data-col="digital">
      Digital<span class="collection-count">{counts.digital}</span>
    </a>
    <a href="/?collection=ai#gallery" class="collection-tab" data-col="ai">
      AI Art<span class="collection-count">{counts.ai}</span>
    </a>
    <a href="/?collection=multimedia#gallery" class="collection-tab" data-col="multimedia">
      Multimedia<span class="collection-count">{counts.multimedia}</span>
    </a>
    <div class="nav-divider" style="width:1px;height:16px;background:var(--ink-faint);opacity:0.4;align-self:center;flex-shrink:0;"></div>
    <a href="/interactive" class="collection-tab">Interactive</a>
    <a href="/video" class="collection-tab">Video</a>
  </div>

  <!-- GALLERY -->
  <section class="gallery-section" id="gallery">
    <div class="gallery-header">
      <h2 class="gallery-title" id="gallery-title">All <em>Works</em></h2>
      <span class="gallery-meta">Hover to explore · Click to enlarge</span>
    </div>
    <div class="gallery-grid">
      {catalog.map(artwork => (
        <div
          class="art-card"
          data-collection={artwork.collection}
          data-slug={artwork.slug}
          onclick={`openLightbox('${artwork.slug}')`}
        >
          {artwork.available && <span class="art-card-badge">Print Available</span>}
          <Image
            class="art-card-img"
            src={getImage(artwork)}
            alt={artwork.title}
            widths={[400, 600]}
            format="webp"
            quality={80}
            loading="lazy"
          />
          <div class="art-card-info">
            <div class="art-card-title">{artwork.title}</div>
            <div class="art-card-meta">
              <span>{collectionLabels[artwork.collection]} · {artwork.year}</span>
              {artwork.available && <span class="art-card-available">Print available</span>}
            </div>
          </div>
        </div>
      ))}

      <!-- Video pieces -->
      <div class="art-card video-card-home" data-collection="video">
        <div class="video-player-home">
          <video src="/video/solar-bloom.mp4" poster="/video/solar-bloom-poster.jpg" preload="none" loop muted playsinline />
          <div class="video-hint-home">Tap to play</div>
        </div>
        <div class="art-card-info" style="opacity:1;transform:none;position:relative;">
          <div class="art-card-title">Solar Bloom</div>
          <div class="art-card-meta"><span>Generative particle art · 2026</span></div>
        </div>
      </div>

      <div class="art-card video-card-home" data-collection="video">
        <div class="video-player-home">
          <video src="/video/the-elders.mp4" poster="/video/the-elders-poster.jpg" preload="none" loop muted playsinline />
          <div class="video-hint-home">Tap to play</div>
        </div>
        <div class="art-card-info" style="opacity:1;transform:none;position:relative;">
          <div class="art-card-title">The Elders</div>
          <div class="art-card-meta"><span>AI-generated video · 2024</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div class="lightbox-overlay" id="lightbox">
    <button class="lightbox-close" onclick="closeLightbox()">✕ Close</button>
    <button class="lightbox-prev" onclick="navLightbox(-1)">&#8592; Prev</button>
    <button class="lightbox-next" onclick="navLightbox(1)">Next &#8594;</button>
    <div class="lightbox-inner">
      {catalog.map(artwork => (
        <div class="lightbox-item" id={`lb-${artwork.slug}`} style="display:none;">
          <Image
            class="lightbox-img"
            src={getImage(artwork)}
            alt={artwork.title}
            widths={[800, 1200]}
            format="webp"
            quality={85}
          />
          <div class="lightbox-info">
            <h2 class="lightbox-title">{artwork.title}</h2>
            <p class="lightbox-medium">{artwork.medium} · {artwork.year}</p>
            <p class="lightbox-desc">{artwork.desc}</p>
            {artwork.available
              ? <a href={`mailto:joe@joefuqua.blog?subject=Inquiry: ${artwork.title}`} class="btn-primary lightbox-cta">Inquire About Print</a>
              : <span class="lightbox-unavailable">Not currently available</span>
            }
          </div>
        </div>
      ))}
    </div>
  </div>

</BaseLayout>

<script is:inline define:vars={{ heroImageUrls }}>
  // Random hero image on load
  const heroImg = document.getElementById('hero-img');
  if (heroImg && heroImageUrls.length) {
    heroImg.src = heroImageUrls[Math.floor(Math.random() * heroImageUrls.length)];
  }

  // Collection filtering
  const titles = {
    all: 'All <em>Works</em>',
    watercolor: 'Watercolor <em>Works</em>',
    digital: 'Digital <em>Drawings</em>',
    ai: 'AI <em>Art</em>',
    multimedia: 'Multimedia <em>Works</em>',
  };

  // Check URL param on load
  const urlParams = new URLSearchParams(window.location.search);
  const initCol = urlParams.get('collection') || 'all';
  if (initCol !== 'all') {
    filterCollection(initCol, false);
  }

  document.querySelectorAll('.collection-tab[data-col]').forEach(tab => {
    tab.addEventListener('click', e => {
      e.preventDefault();
      filterCollection(tab.dataset.col, true);
    });
  });

  function filterCollection(col, scroll) {
    document.querySelectorAll('.art-card').forEach(card => {
      card.classList.toggle('hidden', col !== 'all' && card.dataset.collection !== col);
    });
    const titleEl = document.getElementById('gallery-title');
    if (titleEl) titleEl.innerHTML = titles[col] || titles.all;
    document.querySelectorAll('.collection-tab').forEach(t => {
      t.classList.toggle('active', t.dataset.col === col);
    });
    if (scroll) {
      document.getElementById('gallery')?.scrollIntoView({ behavior: 'smooth' });
    }
  }

  // Lightbox
  const slugs = Array.from(document.querySelectorAll('.art-card')).map(c => c.dataset.slug);

  let currentLightboxSlug = null;

  function getVisibleSlugs() {
    return Array.from(document.querySelectorAll('.art-card:not(.hidden)')).map(c => c.dataset.slug);
  }

  function openLightbox(slug) {
    slugs.forEach(s => {
      const el = document.getElementById('lb-' + s);
      if (el) el.style.display = 'none';
    });
    const target = document.getElementById('lb-' + slug);
    if (target) target.style.display = 'block';
    currentLightboxSlug = slug;
    document.getElementById('lightbox').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('lightbox').classList.remove('active');
    document.body.style.overflow = '';
    currentLightboxSlug = null;
  }

  function navLightbox(dir) {
    if (!currentLightboxSlug) return;
    const visible = getVisibleSlugs();
    const idx = visible.indexOf(currentLightboxSlug);
    if (idx === -1) return;
    const next = (idx + dir + visible.length) % visible.length;
    openLightbox(visible[next]);
  }

  document.getElementById('lightbox').addEventListener('click', function(e) {
    if (e.target === this) closeLightbox();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') navLightbox(1);
    if (e.key === 'ArrowLeft') navLightbox(-1);
  });

  // Video cards — tap to play
  document.querySelectorAll('.video-card-home').forEach(wrap => {
    const video = wrap.querySelector('video');
    const hint = wrap.querySelector('.video-hint-home');
    const player = wrap.querySelector('.video-player-home');
    if (!video || !player) return;
    player.addEventListener('click', () => {
      if (video.paused) { video.play(); } else { video.pause(); }
    });
    video.addEventListener('play', () => { if (hint) hint.style.opacity = '0'; });
    video.addEventListener('pause', () => { if (hint) hint.style.opacity = '1'; });
  });
</script>

<style>
  .video-card-home::after { display: none; }
  .video-player-home {
    position: relative;
    cursor: pointer;
    background: #000;
  }
  .video-player-home video {
    width: 100%;
    display: block;
  }
  .video-hint-home {
    position: absolute;
    bottom: 1rem; left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ink);
    background: rgba(0,0,0,0.6);
    padding: 0.5rem 1.2rem;
    backdrop-filter: blur(4px);
    pointer-events: none;
    transition: opacity 0.3s;
  }
</style>

