---
import BaseLayout from '../layouts/BaseLayout.astro';

const videos = [
  {
    slug: 'solar-bloom',
    title: 'Solar Bloom',
    year: '2026',
    medium: 'Generative particle art',
    desc: 'A pulsing star rendered in real-time — particles erupt in coronal flares and collapse back into the surface.',
  },
  {
    slug: 'the-elders',
    title: 'The Elders',
    year: '2024',
    medium: 'AI-generated video',
    desc: 'Colossal root-creatures loom over a wasted landscape. A man stands in the dust and stares up. They do not notice.',
  },
  {
    slug: 'the-twins',
    title: 'The Twins',
    year: '2024',
    medium: 'AI-generated video',
    desc: 'A daguerreotype that should not exist. Two figures, mouths open, teeth wrong. The silver plate holds them still.',
  },
  {
    slug: 'plague-court',
    title: 'Plague Court',
    year: '2024',
    medium: 'AI-generated video',
    desc: 'A Renaissance court procession — the queen advances, her court in rot and velvet. Nobody leaves this ballroom.',
  },
  {
    slug: 'interface',
    title: 'Interface',
    year: '2024',
    medium: 'AI-generated video',
    desc: 'A face wired open, smiling through the circuitry. The boundary between person and machine is a question nobody asks anymore.',
  },
  {
    slug: 'coastal-station',
    title: 'Coastal Station',
    year: '2024',
    medium: 'AI-generated video',
    desc: 'A retro-futurist outpost perched above the Mediterranean. The alien in yellow has been waiting a very long time.',
  },
  {
    slug: 'geisha-process-1',
    title: 'Geisha with Katana',
    year: '2025',
    medium: 'Animated gel print & watercolor',
    desc: 'A gel print and watercolor piece brought to life — the katana-wielding geisha animated from the original artwork.',
  },
];
---

<BaseLayout title="Video Art" currentPath="/video">

  <!-- COLLECTION NAV -->
  <div class="collection-nav" style="margin-top: var(--header-offset);">
    <a href="/" class="collection-tab">Gallery</a>
    <a href="/interactive" class="collection-tab">Interactive</a>
    <a href="/video" class="collection-tab active">Video</a>
  </div>

  <!-- GALLERY -->
  <section class="gallery-section" id="video">
    <div class="gallery-header">
      <h2 class="gallery-title">Video <em>Art</em></h2>
      <span class="gallery-meta">Tap to play · Best with sound</span>
    </div>
    <div class="gallery-grid">
      {videos.map(v => (
        <div class="art-card video-card-wrap">
          <div class="video-player">
            <video
              src={`/video/${v.slug}.mp4`}
              poster={`/video/${v.slug}-poster.jpg`}
              preload="none"
              loop
              muted
              playsinline
              onclick="this.paused ? this.play() : this.pause()"
            />
            <div class="video-play-hint">Tap to play</div>
          </div>
          <div class="art-card-info" style="opacity: 1; transform: none; position: relative;">
            <div class="art-card-title">{v.title}</div>
            <div class="art-card-meta">
              <span>{v.medium} · {v.year}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>

<script is:inline>
  document.querySelectorAll('.video-card-wrap video').forEach(video => {
    const hint = video.parentElement.querySelector('.video-play-hint');
    video.addEventListener('play', () => { if (hint) hint.style.opacity = '0'; });
    video.addEventListener('pause', () => { if (hint) hint.style.opacity = '1'; });
  });
</script>

<style>
  .video-player {
    position: relative;
    cursor: pointer;
    background: #000;
  }
  .video-player video {
    width: 100%;
    display: block;
  }
  .video-play-hint {
    position: absolute;
    bottom: 1rem; left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ink);
    background: rgba(0,0,0,0.6);
    padding: 0.5rem 1.2rem;
    backdrop-filter: blur(4px);
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .video-card-wrap .art-card-info {
    padding: 1rem 0.5rem;
  }
</style>
