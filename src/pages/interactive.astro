---
import BaseLayout from '../layouts/BaseLayout.astro';
import { catalog } from '../data/catalog';

const counts = {
  all: catalog.length,
  watercolor: catalog.filter(a => a.collection === 'watercolor').length,
  digital: catalog.filter(a => a.collection === 'digital').length,
  ai: catalog.filter(a => a.collection === 'ai').length,
  multimedia: catalog.filter(a => a.collection === 'multimedia').length,
};

const pieces = [
  {
    slug: 'particle-art4',
    title: 'Particle Worlds',
    year: '2026',
    medium: 'WebGL2 · JavaScript',
    desc: 'Generative particle systems rendered in real-time — spiral galaxies, jellyfish blooms, solar flares, and more. Eight scenes with seven color palettes, smooth transitions, and recording support.',
    url: 'https://jbfuqua.github.io/particle-art4/',
    preview: '/video/solar-bloom-poster.jpg',
  },
];
---

<BaseLayout title="Interactive Art" currentPath="/interactive">

  <!-- COLLECTION NAV -->
  <div class="collection-nav" style="margin-top: var(--header-offset);">
    <a href="/" class="collection-tab">
      All<span class="collection-count">{counts.all}</span>
    </a>
    <a href="/?collection=watercolor" class="collection-tab">
      Watercolor<span class="collection-count">{counts.watercolor}</span>
    </a>
    <a href="/?collection=digital" class="collection-tab">
      Digital<span class="collection-count">{counts.digital}</span>
    </a>
    <a href="/?collection=ai" class="collection-tab">
      AI Art<span class="collection-count">{counts.ai}</span>
    </a>
    <a href="/?collection=multimedia" class="collection-tab">
      Multimedia<span class="collection-count">{counts.multimedia}</span>
    </a>
    <div class="nav-divider" style="width:1px;height:16px;background:var(--ink-faint);opacity:0.4;align-self:center;flex-shrink:0;"></div>
    <a href="/interactive" class="collection-tab active">Interactive</a>
    <a href="/video" class="collection-tab">Video</a>
  </div>

  <!-- GALLERY -->
  <section class="gallery-section" id="interactive">
    <div class="gallery-header">
      <h2 class="gallery-title">Interactive <em>Art</em></h2>
      <span class="gallery-meta">Click to launch · Built with code</span>
    </div>
    <div class="gallery-grid">
      {pieces.map(piece => (
        <a
          class="art-card"
          href={piece.url}
          target="_blank"
          rel="noopener"
          style="text-decoration: none; color: inherit;"
        >
          <img
            class="art-card-img"
            src={piece.preview}
            alt={piece.title}
            loading="lazy"
          />
          <div class="art-card-info">
            <div class="art-card-title">{piece.title}</div>
            <div class="art-card-meta">
              <span>{piece.medium} · {piece.year}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
