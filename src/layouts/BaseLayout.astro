---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
}

const {
  title = 'Joe Fuqua',
  description = 'Visual work by Joe Fuqua — watercolor, digital charcoal, AI art, and multimedia pieces made at the boundary between human and machine.',
  currentPath = '',
  ogImage,
} = Astro.props;

const displayTitle = title === 'Joe Fuqua' ? 'Joe Fuqua · Art' : `${title} — Joe Fuqua`;
const canonicalUrl = `https://joefuqua.art${currentPath}`;

const sharedLinks = [
  { href: 'https://joefuqua.com', label: 'Home' },
  { href: 'https://joefuqua.blog', label: 'Writing' },
  { href: 'https://joefuqua.art', label: 'Art' },
  { href: 'https://joefuqua.com/about', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{displayTitle}</title>
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/png" href="/logo.png" />
  <meta property="og:title" content={displayTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={displayTitle} />
  <meta name="twitter:description" content={description} />
</head>
<body>

  <header>
    <div class="header-bar">
      <a href="/" class="site-identity">
        <div class="logo-mark">
          <img src="/logo.png" alt="Joe Fuqua" />
        </div>
        <div>
          <span class="site-name">Joe <span>Fuqua</span></span>
          <span class="site-sub">Art &amp; Visual Work</span>
        </div>
      </a>

      <nav class="site-nav" aria-label="Primary">
        {sharedLinks.map(({ href, label }) => (
          <a href={href} class={href === 'https://joefuqua.art' ? 'active' : ''}>{label}</a>
        ))}
        <div class="nav-divider"></div>
        <a href="/about" class={currentPath === '/about' ? 'active' : ''}>Artist Bio</a>
      </nav>

      <details class="mobile-nav">
        <summary>Menu</summary>
        <nav class="mobile-nav-panel" aria-label="Mobile">
          {sharedLinks.map(({ href, label }) => (
            <a href={href} class={href === 'https://joefuqua.art' ? 'active' : ''}>{label}</a>
          ))}
          <a href="/about" class={currentPath === '/about' ? 'active' : ''}>Artist Bio</a>
          <a href="mailto:joe@joefuqua.blog">Prints &amp; Inquiries</a>
        </nav>
      </details>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-left">
      <div class="footer-name">Joe Fuqua</div>
      <div class="footer-tagline">Writing • Art • Essays on AI</div>
    </div>
    <div class="footer-links">
      <a href="https://joefuqua.com" target="_blank" rel="noopener">joefuqua.com</a>
      <a href="https://joefuqua.blog" target="_blank" rel="noopener">joefuqua.blog</a>
      <a href="https://joefuqua.art" target="_blank" rel="noopener">joefuqua.art</a>
      <a href="https://linkedin.com/in/joe-fuqua" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://instagram.com/the.dim.edge" target="_blank" rel="noopener">@the.dim.edge</a>
      <a href="https://instagram.com/a.nod.tothe.odd" target="_blank" rel="noopener">@a.nod.tothe.odd</a>
      <a href="mailto:joe@joefuqua.blog">Prints &amp; Inquiries</a>
    </div>
  </footer>

</body>
</html>
